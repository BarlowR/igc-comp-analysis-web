---
// Standalone competition flight analysis — all computation runs client-side.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Competition Flight Analysis</title>
    <meta
      name="description"
      content="Upload a task and IGC tracklogs to analyze paragliding competition flights in your browser."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;200;300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="hero">
      <h1>Competition Flight Analysis</h1>
      <p>
        Upload an XContest task file and your pilots' IGC tracklogs. Everything is
        analyzed locally in your browser — nothing is uploaded to a server.
      </p>
    </header>

    <main>
      <section class="card uploader">
        <div class="drop">
          <label class="file-field">
            <span class="field-label">1 · Task file <code>.xctsk</code></span>
            <input id="task-input" type="file" accept=".xctsk,application/json" />
            <span id="task-name" class="field-hint">No task file selected</span>
          </label>

          <label class="file-field">
            <span class="field-label">2 · Pilot tracklogs <code>.igc</code></span>
            <input id="igc-input" type="file" accept=".igc" multiple />
            <span id="igc-count" class="field-hint">No IGC files selected</span>
          </label>
        </div>

        <div class="actions">
          <button id="analyze-btn" type="button" disabled>Analyze flights</button>
          <span id="status" class="status"></span>
        </div>
      </section>

      <div id="results" class="results"></div>
    </main>

    <footer>
      <p>Ported from the <code>comp_analysis</code> Python tooling.</p>
    </footer>

    <script>
      import '../scripts/app.ts';
    </script>

    <style is:global>
      /* Palette and type borrowed from barlowr.com: light warm canvas, near-black
         text, thin Roboto, muted-purple accent. */
      :root {
        --bg: #e7e7e7;
        --panel: #f5efe1;
        --panel-2: #ece3cf;
        --border: rgba(20, 12, 12, 0.35);
        --border-strong: #140c0c;
        --text: #140c0c;
        --muted: #6b625e;
        --accent: #705a90;
        --accent-strong: #5c4878;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: 'Roboto', system-ui, -apple-system, Helvetica, Arial, sans-serif;
        font-weight: 300;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        min-height: 100vh;
      }

      .hero {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 1.5rem 1.5rem;
        text-align: center;
      }

      .hero h1 {
        margin: 0 0 0.5rem;
        font-size: clamp(1.9rem, 4vw, 2.8rem);
        font-weight: 100;
        letter-spacing: 0.01em;
      }

      .hero p {
        margin: 0 auto;
        max-width: 640px;
        color: var(--muted);
      }

      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem 3rem;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--border-strong);
        border-radius: 11px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 1px 3px rgba(20, 12, 12, 0.08);
      }

      .card h2 {
        margin: 0 0 1rem;
        font-size: 1.45rem;
        font-weight: 200;
      }

      .card h3 {
        margin: 1.75rem 0 1rem;
        font-size: 1.1rem;
        font-weight: 300;
        color: var(--muted);
      }

      .uploader .drop {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }

      @media (max-width: 640px) {
        .uploader .drop {
          grid-template-columns: 1fr;
        }
      }

      .file-field {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        background: var(--panel-2);
        border: 1px dashed var(--border);
        border-radius: 10px;
        padding: 1rem;
      }

      .field-label {
        font-weight: 400;
        font-size: 0.95rem;
      }

      .field-label code,
      footer code {
        background: rgba(112, 90, 144, 0.12);
        color: var(--accent);
        padding: 0.05rem 0.35rem;
        border-radius: 5px;
        font-size: 0.85em;
      }

      .field-hint {
        color: var(--muted);
        font-size: 0.85rem;
      }

      input[type='file'] {
        color: var(--muted);
        font-size: 0.85rem;
      }

      input[type='file']::file-selector-button {
        background: var(--panel);
        color: var(--text);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.45rem 0.8rem;
        margin-right: 0.75rem;
        cursor: pointer;
        font: inherit;
      }

      input[type='file']::file-selector-button:hover {
        border-color: var(--accent);
      }

      .actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 1.25rem;
      }

      button#analyze-btn {
        background: var(--accent-strong);
        color: #f5efe1;
        border: none;
        border-radius: 9px;
        padding: 0.65rem 1.4rem;
        font-size: 1rem;
        font-weight: 400;
        cursor: pointer;
        transition: filter 0.15s ease;
      }

      button#analyze-btn:hover:not(:disabled) {
        filter: brightness(1.08);
      }

      button#analyze-btn:disabled {
        opacity: 0.45;
        cursor: not-allowed;
      }

      .status {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .table-wrap {
        overflow-x: auto;
      }

      table.stats {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
      }

      table.stats th,
      table.stats td {
        padding: 0.55rem 0.7rem;
        text-align: right;
        white-space: nowrap;
        border: 1px solid var(--border);
      }

      table.stats th {
        position: sticky;
        top: 0;
        background: var(--panel-2);
        color: var(--text);
        font-weight: 500;
        text-align: right;
        vertical-align: bottom;
      }

      table.stats th:first-child,
      table.stats td.name {
        text-align: left;
        font-weight: 400;
      }

      table.stats th.sortable {
        cursor: pointer;
        user-select: none;
      }

      table.stats th.sortable:hover {
        color: var(--accent);
      }

      /* Leading checkbox column for selecting pilots (linked to the chart). */
      table.stats th.select-col,
      table.stats td.select-col {
        width: 1%;
        text-align: center;
        padding-left: 0.6rem;
        padding-right: 0.6rem;
      }

      table.stats .select-col input {
        cursor: pointer;
        width: 15px;
        height: 15px;
        accent-color: var(--accent-strong);
        vertical-align: middle;
      }

      table.stats tbody tr.unselected {
        opacity: 0.4;
      }

      table.stats tbody tr.unselected:hover {
        opacity: 0.7;
      }

      table.stats td:not(.name) {
        font-variant-numeric: tabular-nums;
      }

      /* Shaded cells carry an explicit rgb() background; dark text reads on them.
         Uncolored cells keep the light theme text so they stay legible. */
      table.gradient td.shaded {
        color: #140c0c;
      }

      table.stats td.name {
        color: var(--text);
      }

      .chart-holder {
        position: relative;
        height: 520px;
      }

      .map-holder {
        height: 560px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border-strong);
      }

      .map-legend {
        background: rgba(245, 239, 225, 0.94);
        color: var(--text);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        padding: 0.5rem 0.6rem;
        font-size: 0.8rem;
        max-height: 320px;
        overflow-y: auto;
        box-shadow: 0 2px 8px rgba(20, 12, 12, 0.15);
      }

      .map-legend-row {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.12rem 0;
        cursor: pointer;
        white-space: nowrap;
      }

      .map-legend-row.off {
        opacity: 0.4;
        text-decoration: line-through;
      }

      .map-legend-swatch {
        display: inline-block;
        width: 14px;
        height: 4px;
        border-radius: 2px;
        flex: 0 0 auto;
      }

      footer {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1rem 1.5rem 3rem;
        color: var(--muted);
        font-size: 0.85rem;
        text-align: center;
      }
    </style>
  </body>
</html>
