---
// Prototype 3D tracklog viewer. Reuses the precomputed [day].json analysis
// (turnpoints + per-pilot tracks with lat/lon/alt/time) and renders it on a
// Cesium globe with an animated, scrubbable timeline. One static route per
// manifest entry, mirroring [day].astro.
import Base from '../../../../layouts/Base.astro';
import manifest from '../../../../archive-manifest.json';

interface Entry {
  comp: string;
  compLabel?: string;
  day: string;
  dayLabel?: string;
  date?: string;
  title?: string;
  utcOffsetMinutes?: number | null;
}

export function getStaticPaths() {
  const entries = manifest as unknown as Entry[];
  return entries.map((entry) => ({ params: { comp: entry.comp, day: entry.day }, props: { entry } }));
}

const { entry } = Astro.props as { entry: Entry };
const base = `/archive/${entry.comp}/${entry.day}`;
const heading = entry.title ?? `${entry.compLabel ?? entry.comp} — ${entry.dayLabel ?? entry.day}`;
const clientEntry = { base, label: heading, utcOffsetMinutes: entry.utcOffsetMinutes ?? null };
---

<Base title={`${heading} — 3D`}>
  <div class="viewer3d">
    <div id="cesiumContainer"></div>

    <!-- Full-screen loading overlay; track3d.ts advances the step text and fades it out. -->
    <div id="loading3d" class="loading3d">
      <div class="loading3d-box">
        <div class="loading3d-spinner" aria-hidden="true"></div>
        <div class="loading3d-title">{heading}</div>
        <div id="loading3d-step" class="loading3d-step">Starting the 3D viewer…</div>
      </div>
    </div>

    <!-- Shared altitude-plot scrubber (mountTimeline) is inserted after this anchor. -->
    <div class="viewer3d-bottom"><div id="timeAnchor"></div></div>

    <div class="panel3d">
      <div class="panel3d-head">
        <h1>{heading}</h1>
        <a class="backlink" href={base}>← 2D analysis</a>
      </div>
      <div id="status3d" class="status3d">Loading globe…</div>
      <div class="panel3d-controls">
        <button id="showAll" type="button">Show all</button>
        <button id="hideAll" type="button">Hide all</button>
      </div>
      <ul id="pilotList" class="pilot-list"></ul>
    </div>
  </div>

  <script type="application/json" id="archive-entry" set:html={JSON.stringify(clientEntry)} />
  <!-- Must run before the Cesium module so it finds its static assets under /cesium. -->
  <script is:inline>window.CESIUM_BASE_URL = "/cesium/";</script>
  <script>
    import '../../../../scripts/track3d.ts';
  </script>
</Base>

<style is:global>
  /* Full-viewport docked layout: pilot table on the left, globe centre, the
     altitude scrubber pinned along the bottom — each a real region, not a
     translucent panel floating over the map. */
  .viewer3d {
    position: fixed;
    inset: 0;
    display: grid;
    grid-template-columns: min(320px, 34vw) 1fr;
    grid-template-rows: 1fr auto;
    grid-template-areas:
      'panel map'
      'slider slider';
    background: var(--bg, #e7e7e7);
  }
  #cesiumContainer {
    grid-area: map;
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 0;
  }
  /* Full-screen loading overlay over the globe. */
  .loading3d {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: grid;
    place-items: center;
    background: var(--bg, #e7e7e7);
    transition: opacity 0.55s ease;
  }
  .loading3d.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .loading3d-box {
    text-align: center;
    padding: 1.5rem;
    max-width: min(90vw, 30rem);
  }
  .loading3d-spinner {
    width: 46px;
    height: 46px;
    margin: 0 auto 1.1rem;
    border-radius: 50%;
    border: 4px solid rgba(20, 12, 12, 0.15);
    border-top-color: var(--accent);
    animation: loading3d-spin 0.9s linear infinite;
  }
  .loading3d.error .loading3d-spinner {
    display: none;
  }
  .loading3d-title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }
  .loading3d-step {
    margin-top: 0.4rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .loading3d.error .loading3d-step {
    color: #c62828;
  }
  @keyframes loading3d-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Bottom dock holding the shared altitude-plot scrubber. */
  .viewer3d-bottom {
    grid-area: slider;
    padding: 0.5rem 0.9rem 0.7rem;
    background: #fff;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }
  /* The reused .time-slider adds a top margin we don't want as the first child. */
  .viewer3d-bottom .time-slider {
    margin-top: 0;
  }

  .panel3d {
    grid-area: panel;
    display: flex;
    flex-direction: column;
    min-height: 0;
    background: #fff;
    border-right: 1px solid rgba(0, 0, 0, 0.12);
    padding: 0.75rem 0.9rem;
    font-size: 0.85rem;
  }
  .panel3d-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .panel3d h1 {
    font-size: 0.98rem;
    font-weight: 500;
    margin: 0 0 0.15rem;
    line-height: 1.25;
  }
  .backlink {
    white-space: nowrap;
    font-size: 0.8rem;
  }
  .status3d {
    color: #6b655c;
    margin: 0.25rem 0 0.5rem;
  }
  .panel3d-controls {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }
  .panel3d-controls button {
    font: inherit;
    padding: 0.2rem 0.55rem;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 6px;
    background: #fff;
    cursor: pointer;
  }
  .pilot-list {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }
  .pilot-list li {
    display: grid;
    grid-template-columns: 1.6em 1.15em minmax(0, 1fr) 3.4em 2.6em 2.9em;
    align-items: center;
    gap: 0.4rem;
    padding: 0.06rem 0.15rem;
    border-radius: 4px;
  }
  .pilot-list li.head {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #fff;
    color: var(--muted);
    font-size: 0.72rem;
    padding-bottom: 0.2rem;
  }
  .pilot-list .rank {
    color: #9a948a;
    font-variant-numeric: tabular-nums;
    text-align: right;
    font-size: 0.78rem;
  }
  .pilot-list .sel-check {
    margin: 0;
    cursor: pointer;
  }
  .pilot-list .nm {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    cursor: pointer;
  }
  .pilot-list .stat {
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    text-align: right;
    font-size: 0.8rem;
  }
  .pilot-list li.off .rank,
  .pilot-list li.off .nm,
  .pilot-list li.off .stat {
    opacity: 0.45;
  }
  .pilot-list li.pinned {
    background: rgba(112, 90, 144, 0.16);
  }
  .pilot-list li.pinned .nm {
    font-weight: 500;
  }
</style>
